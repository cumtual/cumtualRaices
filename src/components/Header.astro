---
import { BurguerMenu } from "./BurguerMenu";
import { Slider } from "./Slider";
import CumtualSVG from "./CumtualSVG.astro";
---

<header class="w-full fixed top-0 left-0 z-30 bg-transparent border-b border-transparent py-5 px-6 md:px-12 transition-all duration-300 ease-out">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <a href="/">
      <div class="flex items-center gap-2 group">
        <div class="transition-transform duration-300 group-hover:scale-105">
          <CumtualSVG />
        </div>
        <p class="text-gradient text-2xl font-bold tracking-tight">Raíces</p>
      </div>
    </a>
    <div>
      <nav class="block md:hidden">
        <BurguerMenu client:load />
      </nav>
      <nav class="hidden md:flex gap-8 items-center">
        <a href="#" class="text-slate-600 hover:text-slate-950 font-medium transition-colors link-underline">Nosotros</a>
        <a href="#" class="text-slate-600 hover:text-slate-950 font-medium transition-colors link-underline">Anuncios</a>
        <a href="#" class="text-slate-600 hover:text-slate-950 font-medium transition-colors link-underline">Blog</a>
        <a href="#" class="text-slate-600 hover:text-slate-950 font-medium transition-colors link-underline">Contacto</a>
      </nav>
    </div>
  </div>
</header>

<Slider client:load />


<script>
  const handleScroll = () => {
    const header = document.querySelector("header");
    if (window.scrollY > 20) {
      header?.classList.add("backdrop-blur-md", "bg-white/80", "border-slate-200/50", "shadow-sm", "py-3");
      header?.classList.remove("bg-transparent", "border-transparent", "py-5");
    } else {
      header?.classList.remove("backdrop-blur-md", "bg-white/80", "border-slate-200/50", "shadow-sm", "py-3");
      header?.classList.add("bg-transparent", "border-transparent", "py-5");
    }
  };

  window.addEventListener("scroll", handleScroll);
  document.addEventListener("astro:after-swap", handleScroll);
</script>
