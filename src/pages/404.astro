---
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="Página no encontrada"
  pageTitle="Página no encontrada"
  description="Lo sentimos, pero la página que buscas no existe."
>
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6 mt-20 md:mt-24 max-w-2xl mx-auto gap-6">
    <h1 class="text-8xl md:text-9xl font-black text-transparent bg-clip-text bg-gradient-to-r from-green-cumtual to-blue-cumtual tracking-tighter">
      404
    </h1>
    <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tight">
      Página no encontrada
    </h2>
    <p class="text-slate-500 font-light max-w-md">
      Lo sentimos, pero la página o propiedad que estás buscando no existe, ha sido eliminada o movida.
    </p>
    <a
      href="/"
      class="inline-flex items-center justify-center px-8 py-3.5 bg-gradient-to-r from-green-cumtual to-blue-cumtual text-white font-semibold rounded-full hover-lift hover-glow transition-all duration-300 shadow-md mt-4"
    >
      Volver al Inicio
    </a>
  </div>
</Layout>
