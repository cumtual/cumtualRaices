---
import Layout from "../layouts/Layout.astro";
import Image from "astro/components/Image.astro";
import IconoSeguridad from "@assets/img/lock.svg";
import IconoPrecio from "@assets/img/payment.svg";
import IconoTiempo from "@assets/img/time.svg";
import IconoDormitorio from "@assets/img/icono_dormitorio.svg";
import IconoEstacionamiento from "@assets/img/icono_estacionamiento.svg";
import IconoBano from "@assets/img/icono_wc.svg";

import { getCollection } from "astro:content";
const casas = await getCollection("casas");
export const prerender = true;
---

<Layout title="Inicio" description="Inicio de Bienes Raíces - Cumtual" pageTitle="Inicio">
  <!-- Hero Section -->
  <section class="relative max-w-7xl mx-auto px-6 md:px-12 mt-28 md:mt-32">
    <div class="relative w-full h-[70vh] md:h-[80vh] min-h-[500px] md:min-h-[600px] rounded-3xl overflow-hidden shadow-2xl">
      <Image
        src="/imgConvertidas/PrincipalHouse.webp"
        alt="Casa de lujo principal"
        class="absolute inset-0 w-full h-full object-cover"
        width={1920}
        height={1080}
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950/85 via-slate-900/40 to-transparent"></div>
      
      <div class="absolute bottom-0 left-0 w-full p-8 md:p-16 flex flex-col items-start gap-6 max-w-4xl">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/20 backdrop-blur-md border border-white/20 rounded-full text-xs md:text-sm font-medium text-white tracking-wider uppercase">
          <span class="w-2 h-2 rounded-full bg-green-cumtual animate-pulse"></span>
          Nuevas propiedades disponibles
        </span>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-tight">
          Venta y Renta de Casas y Departamentos Exclusivos
        </h1>
        <p class="text-slate-200 text-base md:text-lg max-w-2xl font-light">
          Encuentra el hogar de tus sueños en las mejores zonas del país con la asesoría profesional que mereces.
        </p>
        <a
          href="#contacto"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-gradient-to-r from-green-cumtual to-blue-cumtual text-white font-semibold rounded-full hover-lift hover-glow transition-all duration-300 shadow-lg"
        >
          Contáctanos
        </a>
      </div>
    </div>
  </section>

  <!-- Sobre Nosotros (Valores) -->
  <section class="max-w-7xl mx-auto px-6 md:px-12 py-24 md:py-32">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-gradient font-bold uppercase tracking-wider text-sm block mb-3">Filosofía de Servicio</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-950 tracking-tight">
        ¿Por qué elegirnos?
      </h2>
      <p class="text-slate-500 mt-4 font-light text-base md:text-lg">
        Brindamos una experiencia premium enfocada en cumplir tus necesidades inmobiliarias de forma segura y eficiente.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div
        class="bg-white p-8 md:p-10 rounded-3xl border border-slate-100 shadow-sm hover-lift flex flex-col items-center text-center gap-5 transition-all duration-300"
        data-style="value-card"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <div class="w-20 h-20 flex items-center justify-center rounded-2xl bg-green-50">
          <Image
            src={IconoSeguridad}
            width={48}
            height={48}
            alt="Icono seguridad"
            class="w-12 h-12"
          />
        </div>
        <h3 class="text-xl font-bold text-slate-900">Seguridad Total</h3>
        <p class="text-slate-500 font-light text-sm md:text-base leading-relaxed">
          Tu tranquilidad es nuestra prioridad. Procesos 100% transparentes y asesoría legal certificada en cada paso.
        </p>
      </div>

      <div
        class="bg-white p-8 md:p-10 rounded-3xl border border-slate-100 shadow-sm hover-lift flex flex-col items-center text-center gap-5 transition-all duration-300"
        data-style="value-card"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <div class="w-20 h-20 flex items-center justify-center rounded-2xl bg-blue-50">
          <Image 
            src={IconoPrecio} 
            width={48} 
            height={48} 
            alt="Icono pago" 
            class="w-12 h-12"
          />
        </div>
        <h3 class="text-xl font-bold text-slate-900">El Mejor Precio</h3>
        <p class="text-slate-500 font-light text-sm md:text-base leading-relaxed">
          Propiedades tasadas al valor justo del mercado. Opciones de financiamiento a tu medida y sin costos ocultos.
        </p>
      </div>

      <div
        class="bg-white p-8 md:p-10 rounded-3xl border border-slate-100 shadow-sm hover-lift flex flex-col items-center text-center gap-5 transition-all duration-300"
        data-style="value-card"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        <div class="w-20 h-20 flex items-center justify-center rounded-2xl bg-slate-50">
          <Image 
            src={IconoTiempo} 
            width={48} 
            height={48} 
            alt="Icono tiempo" 
            class="w-12 h-12"
          />
        </div>
        <h3 class="text-xl font-bold text-slate-900">Optimización de Tiempo</h3>
        <p class="text-slate-500 font-light text-sm md:text-base leading-relaxed">
          Respuestas rápidas y visitas programadas en minutos. Filtramos las mejores opciones para tu comodidad.
        </p>
      </div>
    </div>
  </section>

  <!-- Casas y depas en venta -->
  <section class="max-w-7xl mx-auto px-6 md:px-12 pb-24 md:pb-32">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-4">
      <div>
        <span class="text-gradient font-bold uppercase tracking-wider text-sm block mb-3">Catálogo</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-950 tracking-tight">
          Nuestras Propiedades
        </h2>
      </div>
      <p class="text-slate-500 font-light max-w-md">
        Explora una selección exclusiva de residencias diseñadas con los más altos estándares de arquitectura y confort.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        casas.map((casa: any) => {
          const { slug, data } = casa;
          const { title, description, img } = data;
          return (
            <section
              class="group bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden flex flex-col hover-lift transition-all duration-300"
              data-aos="fade-up"
            >
              <div class="overflow-hidden relative h-64 bg-slate-100">
                <Image
                  src={`/imgConvertidas/${img}`}
                  width={600}
                  height={450}
                  alt={title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  transition:name={`img-${slug}`}
                />
                <span class="absolute top-4 left-4 inline-flex items-center px-3 py-1 bg-white/90 backdrop-blur-md rounded-full text-xs font-semibold text-slate-900 shadow-sm">
                  Destacado
                </span>
              </div>
              
              <div class="p-6 md:p-8 flex flex-col flex-grow gap-4">
                <h3 class="font-bold text-xl text-slate-900 group-hover:text-blue-cumtual transition-colors">
                  {title}
                </h3>
                <p class="text-slate-500 font-light text-sm leading-relaxed flex-grow">
                  {description}
                </p>
                <div class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-green-cumtual to-blue-cumtual">
                  $3,000,000 MXN
                </div>
                
                <hr class="border-slate-100" />
                
                <div class="flex justify-between items-center text-slate-500 text-sm py-1">
                  <div class="flex items-center gap-2">
                    <Image
                      src={IconoBano}
                      width={20}
                      height={20}
                      alt="baños"
                      class="w-5 h-5 opacity-70"
                    />
                    <span class="font-medium">3</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <Image
                      src={IconoEstacionamiento}
                      width={20}
                      height={20}
                      alt="estacionamientos"
                      class="w-5 h-5 opacity-70"
                    />
                    <span class="font-medium">3</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <Image
                      src={IconoDormitorio}
                      width={20}
                      height={20}
                      alt="dormitorios"
                      class="w-5 h-5 opacity-70"
                    />
                    <span class="font-medium">3</span>
                  </div>
                </div>

                <a
                  class="mt-2 block w-full py-3 bg-slate-50 text-slate-700 font-semibold text-center rounded-2xl hover:bg-slate-900 hover:text-white hover:shadow-lg transition-all duration-300"
                  href={`/casas/${slug}`}
                >
                  Ver Propiedad
                </a>
              </div>
            </section>
          );
        })
      }
    </div>
    
    <div class="flex justify-center mt-12">
      <button
        type="button"
        class="inline-flex items-center justify-center px-8 py-3.5 border border-slate-200 text-slate-700 font-semibold rounded-full hover:bg-slate-900 hover:text-white hover:border-slate-900 transition-all duration-300 hover-lift"
      >
        Ver Todas las Propiedades
      </button>
    </div>
  </section>

  <!-- Banner Encuentra la casa -->
  <section class="max-w-7xl mx-auto px-6 md:px-12 pb-24 md:pb-32" id="contacto">
    <div class="relative w-full h-[450px] rounded-3xl overflow-hidden shadow-2xl">
      <Image
        src="/imgConvertidas/encuentralacasa.webp"
        width={1800}
        height={750}
        alt="Encuentra la casa de tus sueños"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-slate-950/70"></div>
      
      <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-8 max-w-3xl mx-auto gap-6 z-10">
        <h2 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight">
          Encuentra la Casa de tus Sueños
        </h2>
        <p class="text-slate-200 font-light text-base md:text-lg leading-relaxed">
          Llena el formulario de contacto y uno de nuestros asesores especializados se pondrá en contacto contigo a la brevedad.
        </p>
        <button
          type="button"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-gradient-to-r from-green-cumtual to-blue-cumtual text-white font-semibold rounded-full hover-lift hover-glow transition-all duration-300 shadow-lg"
          data-aos="zoom-in"
        >
          Contáctanos
        </button>
      </div>
    </div>
  </section>

  <!-- Blog & Testimonios -->
  <section class="max-w-7xl mx-auto px-6 md:px-12 pb-24 md:pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
      
      <!-- Blog -->
      <div class="lg:col-span-2 flex flex-col gap-8">
        <div>
          <span class="text-gradient font-bold uppercase tracking-wider text-sm block mb-3">Novedades</span>
          <h3 class="text-3xl font-extrabold text-slate-900 tracking-tight">
            Nuestro Blog
          </h3>
        </div>
        
        <div class="flex flex-col gap-6">
          <article
            class="group flex flex-col md:flex-row items-stretch bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden hover-lift transition-all duration-300"
            data-aos="fade-up"
          >
            <div class="md:w-56 h-48 relative overflow-hidden bg-slate-100 flex-shrink-0">
              <Image
                src="/imgConvertidas/rooftop.webp"
                width={300}
                height={300}
                alt="Terraza en el techo de tu casa"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-6 md:p-8 flex flex-col justify-center gap-3">
              <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">
                Diseño & Exteriores
              </span>
              <h4 class="font-bold text-xl text-slate-900 group-hover:text-blue-cumtual transition-colors">
                Terraza en el techo de tu casa
              </h4>
              <p class="text-slate-500 font-light text-sm line-clamp-2">
                Consejos para disfrutar de la mejor vista a tus alrededores de tu departamento o desde lo más alto de tu propiedad.
              </p>
              <div class="flex items-center gap-2 text-xs text-slate-400 mt-2">
                <span>Escrito el: <strong class="text-green-cumtual font-medium">12/12/2024</strong></span>
                <span>•</span>
                <span>Por: <strong class="text-blue-cumtual font-medium">Luis</strong></span>
              </div>
            </div>
          </article>

          <article
            class="group flex flex-col md:flex-row items-stretch bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden hover-lift transition-all duration-300"
            data-aos="fade-up"
            data-aos-delay="100"
          >
            <div class="md:w-56 h-48 relative overflow-hidden bg-slate-100 flex-shrink-0">
              <Image
                src="/imgConvertidas/interiores.webp"
                width={300}
                height={300}
                alt="La importancia de los interiores"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-6 md:p-8 flex flex-col justify-center gap-3">
              <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">
                Arquitectura & Confort
              </span>
              <h4 class="font-bold text-xl text-slate-900 group-hover:text-blue-cumtual transition-colors">
                La importancia de los interiores
              </h4>
              <p class="text-slate-500 font-light text-sm line-clamp-2">
                Consejos para un mejor espacio en tus interiores, destacando la importancia de un diseño moderno y minimalista.
              </p>
              <div class="flex items-center gap-2 text-xs text-slate-400 mt-2">
                <span>Escrito el: <strong class="text-green-cumtual font-medium">12/12/2024</strong></span>
                <span>•</span>
                <span>Por: <strong class="text-blue-cumtual font-medium">Luis</strong></span>
              </div>
            </div>
          </article>
        </div>
      </div>
      
      <!-- Testimonios -->
      <div class="flex flex-col gap-8">
        <div>
          <span class="text-gradient font-bold uppercase tracking-wider text-sm block mb-3">Experiencias</span>
          <h3 class="text-3xl font-extrabold text-slate-900 tracking-tight">
            Testimonios
          </h3>
        </div>
        
        <div 
          class="bg-gradient-to-br from-cumtual-dark to-slate-900 text-white p-8 md:p-10 rounded-3xl shadow-xl flex flex-col justify-between relative overflow-hidden group min-h-[300px]" 
          data-aos="fade-up"
        >
          <!-- Giant quote marks in background -->
          <div class="absolute -right-4 -bottom-8 text-[12rem] font-serif text-white/5 pointer-events-none select-none">
            ”
          </div>
          
          <div class="relative z-10">
            <span class="text-green-cumtual text-4xl block mb-4 font-serif">“</span>
            <p class="text-slate-200 font-light text-base md:text-lg leading-relaxed">
              El personal se comportó excelente, llevando el proceso de manera muy atenta y respetable, lo que me ofrecieron cumplió totalmente mis expectativas.
            </p>
          </div>
          
          <div class="flex items-center gap-4 mt-8 relative z-10 border-t border-white/10 pt-6">
            <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-green-cumtual to-blue-cumtual flex items-center justify-center font-bold text-white shadow-sm text-sm">
              FA
            </div>
            <div>
              <p class="font-semibold text-white text-sm">Fernando Arias</p>
              <p class="text-xs text-slate-400">Cliente Satisfecho</p>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </section>
</Layout>
